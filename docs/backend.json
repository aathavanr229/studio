
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Premium member profile information",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "membershipLevel": { "type": "string", "enum": ["Standard", "Gold", "Platinum"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    }
  }
}
